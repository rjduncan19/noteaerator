<Window x:Class="Noteaerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Note Aerator (POC)"
        Height="800" Width="1200"
        Background="{StaticResource BgBrush}"
        Icon="app.ico"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{x:Static ApplicationCommands.Find}"/>
        <KeyBinding Key="Escape" Command="{x:Static ApplicationCommands.Close}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Find}"
                        Executed="OnOpenSearchExecuted"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Close}"
                        Executed="OnCloseSearchExecuted"
                        CanExecute="OnCloseSearchCanExecute"/>
    </Window.CommandBindings>
    <Grid>
        <DockPanel>
            <!-- App header / toolbar -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True" Margin="14,8">
                    <!-- App title (left) -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="app.ico" Width="22" Height="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Aerate your Notes"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Search button (top right corner) -->
                    <Button x:Name="SearchButton"
                            DockPanel.Dock="Right"
                            Content="&#x1F50D;"
                            FontSize="16"
                            Padding="8,4"
                            ToolTip="Search (Ctrl+F)"
                            Click="OnSearchButtonClick"/>

                    <!-- Status (right of buttons, left of search) -->
                    <TextBlock x:Name="StatusText"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="600"
                               Margin="0,0,12,0"
                               HorizontalAlignment="Right"/>

                    <!-- Buttons (center-left) -->
                    <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <Button Content="Add project folder…" Click="OnAddProject" Margin="0,0,8,0"/>
                        <Button Content="Refresh" Click="OnRefresh"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Horizontal tabs = projects (directories) -->
            <TabControl x:Name="ProjectsTabs"
                        Style="{StaticResource ProjectTabControlStyle}"
                        TabStripPlacement="Top"
                        SelectionChanged="OnProjectChanged"/>
        </DockPanel>

        <!-- Search overlay (top-right, hidden by default).
             Hosted in a Popup so it can paint OVER the WebView2 native HWND
             (WPF z-order doesn't apply to native children — WebView2 would
             otherwise clip a normal in-Grid overlay). -->
        <Popup x:Name="SearchPopup"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=ProjectsTabs}"
               HorizontalOffset="0" VerticalOffset="0"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade"
               Closed="OnSearchPopupClosed">
            <Border x:Name="SearchPanel"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="440"
                    MaxHeight="600"
                    Margin="0,8,16,16">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.18" BlurRadius="20" ShadowDepth="4"/>
                </Border.Effect>
                <DockPanel Margin="12" LastChildFill="True">
                    <!-- Header: input + close -->
                    <DockPanel DockPanel.Dock="Top" LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Content="&#x2715;"
                                Padding="8,4"
                                Margin="6,0,0,0"
                                ToolTip="Close (Esc)"
                                Click="OnCloseSearchClick"/>
                        <TextBox x:Name="SearchInput"
                                 FontSize="13"
                                 Padding="8,6"
                                 KeyDown="OnSearchInputKeyDown"
                                 TextChanged="OnSearchInputChanged"/>
                    </DockPanel>

                    <!-- Scope radios -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,8,0,0">
                        <RadioButton x:Name="ScopeProject" Content="Whole project" IsChecked="True"
                                     GroupName="SearchScope" Checked="OnScopeChanged"
                                     VerticalAlignment="Center"/>
                        <RadioButton x:Name="ScopeFile" Content="This file" Margin="14,0,0,0"
                                     GroupName="SearchScope" Checked="OnScopeChanged"
                                     VerticalAlignment="Center"/>
                        <TextBlock x:Name="SearchSummary" Margin="14,0,0,0"
                                   Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Results -->
                    <ListBox x:Name="SearchResults"
                             Margin="0,10,0,0"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MouseDoubleClick="OnSearchResultActivate"
                             KeyDown="OnSearchResultsKeyDown">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="3,0,0,0"
                                                    CornerRadius="0,4,4,0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource SelectedBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Display1}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Display2}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
