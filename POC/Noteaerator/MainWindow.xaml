<Window x:Class="Noteaerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="noteaerator (POC)"
        Height="800" Width="1200"
        Background="{StaticResource BgBrush}"
        Icon="app.ico"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <DockPanel>
        <!-- App header / toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" Margin="14,8">
                <!-- App title (left) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="app.ico" Width="20" Height="20" Margin="0,0,8,0"/>
                    <TextBlock Text="noteaerator"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="  ·  POC"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Status (right) -->
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="500"
                           HorizontalAlignment="Right"/>

                <!-- Buttons (center-left) -->
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Button Content="Add project folder…" Click="OnAddProject" Margin="0,0,8,0"/>
                    <Button Content="Remove project" Click="OnRemoveProject" Margin="0,0,8,0"/>
                    <Button Content="Refresh" Click="OnRefresh"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Horizontal tabs = projects (directories) -->
        <TabControl x:Name="ProjectsTabs"
                    Style="{StaticResource ProjectTabControlStyle}"
                    TabStripPlacement="Top"
                    SelectionChanged="OnProjectChanged"/>
    </DockPanel>
</Window>
